{
  "server": {
    "host": "127.0.0.1",
    "port": 8765,
    "env": "dev"
  },
  "stt": {
    "model_name": "small",
    "device": "cpu",
    "compute_type": "int8",
    "language": "ko",
    "sample_rate": 16000,
    "default_profile": "default",
    "emit_debug_state": false,
    "profiles": {
      "default": {
        "frame_ms": 20,
        "calibration_seconds": 1.2,
        "start_multiplier": 2.8,
        "end_multiplier": 1.8,
        "min_start_ms": 80,
        "min_end_ms": 280,
        "noise_ema_alpha": 0.08,
        "min_rms_floor": 0.003,
        "pre_roll_ms": 120,
        "partial_interval_ms": 600
      },
      "ultra_low_latency": {
        "frame_ms": 10,
        "calibration_seconds": 0.8,
        "start_multiplier": 2.6,
        "end_multiplier": 1.7,
        "min_start_ms": 40,
        "min_end_ms": 160,
        "noise_ema_alpha": 0.1,
        "min_rms_floor": 0.003,
        "pre_roll_ms": 60,
        "partial_interval_ms": 220
      }
    }
  }
}
