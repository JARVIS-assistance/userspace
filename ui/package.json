{
  "name": "jarvis-userspace",
  "productName": "JARVIS Userspace",
  "version": "1.0.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "build": "node build.js",
    "start": "npm run build && electron .",
    "pack:mac": "npm run build && electron-builder --mac dir",
    "dist:mac": "npm run build && electron-builder --mac dmg"
  },
  "build": {
    "appId": "com.jarvis.userspace",
    "productName": "JARVIS Userspace",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dir"
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.21.5"
  }
}
